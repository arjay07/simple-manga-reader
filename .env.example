# Path to your manga folder on the host machine
# Windows example: C:/Users/yourname/manga
# Linux example: /home/yourname/manga
MANGA_DIR_HOST=/path/to/your/manga

# Primary domain for external HTTPS access (required)
# Create a free subdomain at https://www.duckdns.org or use your own domain
PRIMARY_DOMAIN=your-subdomain.duckdns.org

# DNS provider name as used in Caddy (default: duckdns)
# See https://github.com/caddy-dns for supported providers
DNS_PROVIDER=duckdns

# API token for your DNS provider (required)
DNS_TOKEN=your-dns-token

# xcaddy DNS plugin module to build Caddy with (default: DuckDNS)
# Change this if using a different DNS provider, e.g.:
#   Cloudflare: github.com/caddy-dns/cloudflare
#   Namecheap:  github.com/caddy-dns/namecheap
# DNS_PLUGIN=github.com/caddy-dns/duckdns

# Optional: secondary domain (e.g. for Tailscale or local network access)
# SECONDARY_DOMAIN=your-other-subdomain.duckdns.org

# Port to expose the app on (default: 3000)
# PORT=3000

# Optional: URL path prefix when serving behind a reverse proxy at a sub-path
# e.g. /manga makes the app available at https://yourdomain.com/manga
# NEXT_PUBLIC_BASE_PATH=/manga

# Google API key for downloading manga from Google Drive
# Required for the "Add from GDrive" feature in Admin Mode
# Get one at https://console.cloud.google.com/apis/credentials
# GOOGLE_API_KEY=your_api_key_here
